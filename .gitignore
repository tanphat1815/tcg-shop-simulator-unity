# =============================================
# Unity Project
# Standard Unity + cross-tooling .gitignore
# =============================================

# --- Unity Generated (never commit) ---

# Core autogenerated folders
Library/
Temp/
Obj/
Logs/
ShaderCache/
ShaderCompilers/

# Build outputs
Build/
Builds/
[Ll]ocal[Bb]uild/

# User settings (editor layout, preferences)
UserSettings/

# Memory / GPU captures
MemoryCaptures/

# Lock files
UnityLockfile

# Crash reports
crash_handlers/

# Source control config (auto-generated by Unity)
.vsconfig

# --- Generated project files ---

# Visual Studio
*.user
*.userosscache
*.sln.docstates
*.suo
*.cache
*.userprefs
*.pdb

# JetBrains Rider
*.sln.imod
*.csproj.user

# MonoDevelop (legacy)
*.mdb

# All solution / project files (autogenerated by Unity each time you open)
*.sln
*.slnx
*.csproj
*.booproj
*.svd
*.pidb
*.opendb
*.db
*.sqlite

# --- Unity Package Manager ---

# All sub-folders in Packages/ are generated; keep only the lock files.
Packages/*/
!Packages/manifest.json
!Packages/packages-lock.json

# --- Asset dependencies (machine-specific) ---

# Unity 2020.3+ stores external asset links here — do NOT commit.
[Ll]ibrary/

# --- Platform-specific builds & artifacts ---

*.apk
*.aab
*.app
*.dylib
*.so
*.dll
*.exe
*.unitypackage
*.zip
*.tar
*.tar.gz
sysinfo.txt

# --- PlasticSCM / Collab ---
.collabignore
.collabignore~

# --- OS / IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# =============================================
# Cross-tooling rules (Node, Python, Claude Code, etc.)
# =============================================

# Environment files
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# API keys and secrets
*.key
*.pem
secrets.json
config/secrets.yml
.secrets

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.yarn/
lerna-debug.log*

# Build outputs
dist/
build/
*.tsbuildinfo
.cache/

# Test coverage
coverage/
.nyc_output/

# Logs
logs/
*.log

# Python
__pycache__/
*.pyc

# Claude Code teams
tasks/
personal/
private/

# Claude Code sessions
examples/sessions/*.tmp

# Claude Code local drafts / worktrees
.dmux/
.dmux-hooks/
.claude/worktrees/
.claude/scheduled_tasks.lock

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.backup

# Observer temp files
.observer-tmp/

# Rust build artifacts
ecc2/target/

# Bootstrap pipeline outputs
.opencode/package-lock.json
.opencode/node_modules/
assets/images/security/badrudi-exploit.mp4

# --- Custom project ignores ---

# AI/Cursor instructions
step-*-cursor-instructions.md

# Unity Asset Store / Imported Packages (Bloat)
**/Assets/TextMesh Pro/Examples & Extras/
**/Assets/TextMesh Pro/Examples & Extras.meta
**/Assets/Adaptive Performance/
**/Assets/Adaptive Performance.meta
